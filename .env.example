# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sensoplus
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRES_IN=15m          # Access token — courte durée
REFRESH_TOKEN_TTL=30d       # Refresh token — longue durée

# CORS — séparer plusieurs origines par une virgule
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Notifications push — Firebase Admin SDK
# Récupérer ces valeurs dans Firebase Console > Paramètres du projet > Comptes de service
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
